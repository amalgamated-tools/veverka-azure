# Override variables here (local only, not committed to git)
# 
# SSH Key: MUST be RSA (ssh-rsa), NOT ed25519
# To generate:
#   ssh-keygen -t rsa -b 4096 -f ~/.ssh/azure_rsa -C "azure@veverka"
# To get from 1Password (new format):
#   op item get "<ssh-key-name>" --format=json | jq -r '.fields[] | select(.id=="public_key") | .value'
#
# Tailscale auth key:
#   https://login.tailscale.com/admin/settings/keys (generate reusable key)
#
# Cloudflare Tunnel token:
#   https://dash.cloudflare.com/ → Zero Trust → Networks → Tunnels
#
# Example:
# ssh_public_key            = "ssh-rsa AAAAB3NzaC1yc2EA..."
# tailscale_auth_key        = "tskey-xxxxxxxxxxxxxxxxxxxxxxxx"
# cloudflare_tunnel_token   = "xxxxxxxx-xxxxx-xxxxx"
# location                  = "East US"

